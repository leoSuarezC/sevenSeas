# Copy to .env and adjust as needed. Never commit .env — no real secrets here.
# Synthetic seed data only; this project never touches real patient data.

# --- Database -----------------------------------------------------------------
# Windows (default): SQL Server LocalDB — nothing to install or run.
ConnectionStrings__SpecimenCheckIn=Server=(localdb)\MSSQLLocalDB;Database=SpecimenCheckIn;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True

# macOS / Linux: use docker-compose.yml instead, and swap in this connection string.
# ConnectionStrings__SpecimenCheckIn=Server=localhost,1433;Database=SpecimenCheckIn;User Id=sa;Password=Local_Dev_Pa55w0rd!;TrustServerCertificate=True

# --- API ----------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Development

# --- Front-end ----------------------------------------------------------------
# Base URL the Vue dev server calls.
VITE_API_BASE_URL=http://localhost:5080

# Tenant (lab) the stubbed session acts as. Sent as the X-Lab-Id header on every
# request. Isolation is enforced on the server; this only chooses who you are.
# Seeded labs: 1 = Riverside Clinic Lab, 2 = Northgate Derm Lab.
VITE_LAB_ID=1
